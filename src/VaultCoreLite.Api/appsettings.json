{
  "ConnectionStrings": {
    "VaultDb": "Host=localhost;Port=5432;Database=vaultlite;Username=vaultlite_app;Password=vaultlite_app"
  },
  "ProductRuntime": {
    "Mode": "Stub",
    "PluginPath": "plugins/BankProducts.Plugin.dll",
    "RequireAuthenticode": false
  },
  "SchedulerWorker": {
    "Enabled": true,
    "PollIntervalSeconds": 15,
    "BatchSize": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
